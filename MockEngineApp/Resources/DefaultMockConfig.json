{
  "settings": {
    "port": 8080,
    "logRequests": true,
    "bindAddress": "127.0.0.1"
  },
  "routes": [
    {
      "id": "health-check",
      "request": {
        "method": "GET",
        "urlPattern": "/health"
      },
      "response": {
        "statusCode": 200,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"status\":\"ok\"}"
      },
      "priority": 100
    },
    {
      "id": "list-users",
      "request": {
        "method": "GET",
        "urlPattern": "/api/users"
      },
      "response": {
        "statusCode": 200,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"users\":[{\"id\":1,\"name\":\"Alice\"},{\"id\":2,\"name\":\"Bob\"}]}"
      }
    },
    {
      "id": "get-user-by-id",
      "request": {
        "method": "GET",
        "urlPattern": "/api/users/{id}"
      },
      "response": {
        "statusCode": 200,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"id\":1,\"name\":\"Alice\",\"email\":\"alice@example.com\"}"
      },
      "priority": 10
    },
    {
      "id": "create-user",
      "request": {
        "method": "POST",
        "urlPattern": "/api/users"
      },
      "response": {
        "statusCode": 201,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"id\":42,\"created\":true}"
      }
    },
    {
      "id": "catch-all",
      "request": {
        "method": "GET",
        "urlPattern": "/**"
      },
      "response": {
        "statusCode": 200,
        "headers": { "Content-Type": "text/plain" },
        "body": "MockEngine is running"
      },
      "priority": -100
    }
  ]
}
